{
  "name": "code-translate-monorepo",
  "private": true,
  "workspaces": [
    "packages/lsp"
  ],
  "scripts": {
    "build": "npm run build -w packages/lsp",
    "bootstrap": "npm run bootstrap -w packages/lsp",
    "test": "npm run test -w packages/lsp",
    "lint": "npm run lint -w packages/lsp",
    "format": "npm run format -w packages/lsp",
    "format:zed": "cargo fmt --manifest-path packages/zed/Cargo.toml -- --check",
    "check:zed": "cargo check --locked --manifest-path packages/zed/Cargo.toml",
    "check:zed:wasm": "cargo check --locked --manifest-path packages/zed/Cargo.toml --target wasm32-wasip2",
    "validate:bootstrap": "node --test packages/lsp/test/bootstrap.test.js",
    "validate:manifest": "cargo test --locked --manifest-path packages/zed/Cargo.toml manifest_",
    "validate:package": "npm run validate:package -w packages/lsp",
    "validate:node": "npm test && npm run lint && npm run format && npm run build",
    "validate:zed": "npm run format:zed && npm run check:zed && npm run check:zed:wasm && npm run validate:manifest",
    "validate": "npm run validate:node && npm run validate:zed && npm run validate:package && npm run validate:bootstrap"
  }
}
